# Company Catcher — 환경 변수 템플릿
# 이 파일을 복사해 .env로 저장 후 실제 키를 입력하세요.
# 절대로 실제 API 키를 이 파일에 입력하지 마세요!

# DART OpenDART API 키 (일일 10,000 호출 한도)
# https://opendart.fss.or.kr/ 에서 발급
DART_API_KEY=your_dart_api_key_here

# Anthropic API 키 (Claude Sonnet 비교분석 시 선택사항)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API 키
# 파싱1: 기본 키 (Flash 500 RPD + Flash-Lite 1000 RPD)
GEMINI_API_KEY=your_gemini_api_key_1_here
# 파싱2: 보조 키 — 두 키 합산 시 Flash 1,000 RPD / Pro 200 RPD
GEMINI_API_KEY_2=your_gemini_api_key_2_here

# AI 분석 API 보안 키 (자동 생성 — python -c "import secrets; print(secrets.token_urlsafe(32))")
API_SECRET_KEY=your_random_secret_key_here
